# =====================================================================
# wifi-combat-lms-frontend — Vercel Environment Variables
# Add in: Vercel Dashboard → Project → Settings → Environment Variables
# =====================================================================

# Your Railway backend URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://your-railway-backend.up.railway.app

# All versioned aliases — set the same Railway URL for staging
NEXT_PUBLIC_BASE_URL_1=https://your-railway-backend.up.railway.app
NEXT_PUBLIC_BASE_URL_2=https://your-railway-backend.up.railway.app
NEXT_PUBLIC_BASE_URL_3=https://your-railway-backend.up.railway.app
NEXT_PUBLIC_BASE_URL_4=https://your-railway-backend.up.railway.app
